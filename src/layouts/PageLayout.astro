---
import Layout from './Layout.astro';

interface Props {
	title?: string;
	description?: string;
	frontmatter?: {
		title?: string;
		description?: string;
	};
}

const props = Astro.props as Props;
const frontmatter = props.frontmatter ?? {};
const title = props.title ?? frontmatter.title ?? 'new customers';
const description = props.description ?? frontmatter.description ?? '';
const metaDescription = description?.trim() || title.replace(/\s*-\s*new customers$/i, '').trim();
---

<Layout title={title} description={metaDescription}>
	<slot />
</Layout>
