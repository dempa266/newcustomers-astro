---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import Button from '../components/Button.astro';
import { parseEncodedJson } from '../components/utils';

interface Feature {
	image?: {
		url?: string;
	};
	title?: string;
	description?: string;
}

interface Props {
	data?: {
		preTitle?: string;
		title?: string;
		description?: string;
		buttonText?: string;
		buttonLink?: string;
		features?: string;
	};
}

const { data = {} } = Astro.props as Props;
const features = parseEncodedJson<Feature[]>(data.features, []);
---

<section class="section-spacing" aria-label="Metod">
	<div class="site-container">
		<div class="lg:flex justify-between gap-10">
			<div class="max-w-xl my-auto section-intro section-intro--spaced" data-reveal>
				{data.preTitle && <SectionEyebrow text={data.preTitle} />}
				{data.title && <h2>{data.title}</h2>}
				{data.description && <p class="type-section-lead prose-measure">{data.description}</p>}
			</div>
			{data.buttonText && (
				<div class="max-w-sm mt-2 lg:my-auto">
					<Button type="primary" size="lg" href={data.buttonLink ?? '#'} text={data.buttonText} />
				</div>
			)}
		</div>

		<div class="section-after-intro features-columns" data-reveal-children>
			{features.map((feature, i) => (
				<div class="features-column flow">
					<span class="shrink-0 font-[var(--font-heading)] text-[clamp(2rem,3.2vw,2.8rem)] font-bold leading-none text-primary tabular-nums">
						{String(i + 1).padStart(2, '0')}
					</span>
					{feature.title && <h3 class="text-foreground">{feature.title}</h3>}
					{feature.description && <p class="leading-relaxed max-w-[40ch]">{feature.description}</p>}
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features-columns {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		padding-top: clamp(2rem, 3.5vw, 3rem);
	}

	@media (min-width: 768px) {
		.features-columns {
			grid-template-columns: repeat(3, 1fr);
			gap: 0;
		}

		.features-column {
			padding-block: 0.5rem;
		}

		.features-column:not(:first-child) {
			padding-left: clamp(1.5rem, 3vw, 3rem);
			border-left: 1px solid color-mix(in oklab, var(--foreground) 6%, transparent);
		}

		.features-column:not(:last-child) {
			padding-right: clamp(1.5rem, 3vw, 3rem);
		}
	}
</style>
