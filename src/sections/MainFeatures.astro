---
import Button from '../components/Button.astro';
import { parseEncodedJson } from '../components/utils';

interface Feature {
	image?: {
		url?: string;
	};
	title?: string;
	description?: string;
}

interface Props {
	data?: {
		preTitle?: string;
		title?: string;
		description?: string;
		buttonText?: string;
		buttonLink?: string;
		features?: string;
	};
}

const { data = {} } = Astro.props as Props;
const features = parseEncodedJson<Feature[]>(data.features, []);
---

<section class="section-spacing">
	<div class="site-container">
	<div class="lg:flex justify-between">
		<div class="max-w-lg my-auto space-y-2">
			{data.preTitle && <div class="text-base font-medium text-primary uppercase">{data.preTitle}</div>}
			{data.title && <h2 class="text-4xl text-gray mt-0">{data.title}</h2>}
			{data.description && <div class="text-gray-500">{data.description}</div>}
		</div>
		{data.buttonText && (
			<div class="max-w-sm mt-10 lg:my-auto">
				<Button type="primary" href={data.buttonLink ?? '#'} text={data.buttonText} />
			</div>
		)}
	</div>
	<div class="grid w-full gap-6 grid-cols-1 sm:grid-cols-3 mt-10">
		{features.map((feature) => (
			<div class="text-center flex flex-col items-center">
				{feature.image?.url && (
					<div class="relative w-full h-64 flex overflow-hidden rounded-2xl">
						<img src={feature.image.url} alt={feature.title ?? ''} class="object-cover" width="1024" height="1024" loading="lazy" />
					</div>
				)}
				<h3 class="text-gray mt-4 text-2xl">{feature.title}</h3>
				<p class="text-gray-500 max-w-xs">{feature.description}</p>
			</div>
		))}
	</div>
	</div>
</section>
