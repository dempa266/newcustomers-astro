---
import { parseEncodedJson } from '../components/utils';

interface Feature {
	title?: string;
}

interface Props {
	data?: {
		preTitle?: string;
		title?: string;
		description?: string;
		image?: string;
		features?: string;
	};
}

const { data = {} } = Astro.props as Props;
const features = parseEncodedJson<Feature[]>(data.features, []);
---

<section class="section-spacing">
	<div class="site-container">
	<div class="lg:flex justify-between gap-10">
		<div class="max-w-xl my-auto section-intro section-intro--spaced">
			{data.preTitle && <div class="text-base font-medium text-primary uppercase">{data.preTitle}</div>}
			{data.title && <h2>{data.title}</h2>}
			{data.description && <p class="text-muted prose-measure">{data.description}</p>}
		</div>
		{data.image && (
			<div class="surface-card relative max-w-xl aspect-[4/3] w-full flex overflow-hidden my-2 lg:my-0">
				<img src={data.image} alt={data.title ?? ''} class="object-cover w-full h-full" loading="lazy" />
			</div>
		)}
	</div>
	<div class="section-after-intro grid w-full gap-6 grid-cols-1 sm:grid-cols-3">
		{features.map((feature) => (
			<div class="surface-card-muted items-center p-6">
				<div class="font-medium flex">
					<span class="w-6 h-6 text-primary">✓</span>
					<div class="ml-6">{feature.title}</div>
				</div>
			</div>
		))}
	</div>
	</div>
</section>
