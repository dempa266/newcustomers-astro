---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { parseEncodedJson } from '../components/utils';

interface Props {
	data?: {
		eyebrow?: string;
		title?: string;
		description?: string;
		services?: string;
	};
}

const { data = {} } = Astro.props as Props;
const services = parseEncodedJson<string[]>(data.services, []);
---

<section class="section-spacing" aria-label={data.eyebrow ?? 'Tjänster'}>
	<div class="site-container">
		<div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-8 lg:gap-16 items-start">
			<div class="section-intro lg:sticky lg:top-28" data-reveal>
				{data.eyebrow && <SectionEyebrow text={data.eyebrow} />}
				{data.title && <h2>{data.title}</h2>}
				{data.description && <p class="type-section-lead prose-measure">{data.description}</p>}
			</div>
			<div class="section-after-intro grid grid-cols-1 sm:grid-cols-2 gap-x-12" data-reveal-children>
				{services.map((service, i) => (
					<div class="py-5 border-b border-black/6 flex items-baseline gap-4">
						<span class="shrink-0 font-[var(--font-heading)] text-sm font-semibold text-primary tabular-nums">
							{String(i + 1).padStart(2, '0')}
						</span>
						<span class="text-foreground font-medium">{service}</span>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
