---
import Button from '../components/Button.astro';
import { parseEncodedJson } from '../components/utils';

interface Props {
	h1?: string;
	description?: string;
	data?: {
		title?: string;
		description?: string;
		image?: string;
		video?: string;
	};
}

const { h1, description, data = {} } = Astro.props as Props;
const video = parseEncodedJson<{ url?: string }>(data.video, {});
const title = data.title ?? h1;
const text = data.description ?? description;
---

<section class="section-spacing">
	<div class="site-container">
		<div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20 text-gray">
			<div class="my-auto section-intro">
				{title && <h1>{title}</h1>}
				{text && <p class="prose-measure">{text}</p>}
				<div class="flex flex-wrap gap-3 pt-2">
					<Button href="/kontakt/" type="primary" size="lg" text="Kontakt" />
					<Button href="/om-oss/" type="secondary" size="lg" text="Om oss" />
				</div>
			</div>

			{data.image && (
				<div class="flex aspect-[4/3] w-full overflow-hidden rounded-[var(--radius-card)]">
					<img src={data.image} alt={title ?? ''} class="object-cover w-full h-full" loading="lazy" />
				</div>
			)}

			{video.url && (
				<figure class="flex aspect-[4/3] w-full overflow-hidden rounded-[var(--radius-card)] wp-block-video">
					<video class="w-full h-full object-fit" autoplay loop muted src={video.url} playsinline></video>
				</figure>
			)}
		</div>
	</div>
</section>
