---
import Button from "../components/Button.astro";
import { parseEncodedJson } from "../components/utils";

interface Props {
  h1?: string;
  description?: string;
  data?: {
    title?: string;
    description?: string;
    image?: string;
    video?: string;
  };
}

const { h1, description, data = {} } = Astro.props as Props;
const video = parseEncodedJson<{ url?: string }>(data.video, {});
const title = data.title ?? h1;
const text = data.description ?? description;
---

<section class="section-spacing relative overflow-hidden">
  {/* Background blob subtle gradient - optional modern touch */}
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-surface pointer-events-none -z-10"
  >
  </div>

  <div class="site-container relative z-10">
    <div class="grid items-center gap-16 lg:grid-cols-2 lg:gap-24 text-gray">
      <div
        class="my-auto section-intro flex flex-col items-start gap-6 lg:max-w-xl"
      >
        {
          title && (
            <h1 class="text-4xl sm:text-5xl lg:text-h1 font-bold tracking-tight text-foreground leading-tight">
              {title}
            </h1>
          )
        }
        {
          text && (
            <p class="text-lg sm:text-xl text-text-muted prose-measure leading-relaxed font-light">
              {text}
            </p>
          )
        }

        <div class="flex flex-wrap gap-4 pt-4 w-full sm:w-auto">
          {
            /* Updated button classes assuming the global CSS button--primary is styled, adding explicit padding/shadow for a modern feel */
          }
          <Button
            href="/kontakt/"
            type="primary"
            size="lg"
            text="Kontakt"
            *
            class="shadow-lg shadow-primary/30 hover:shadow-primary/50 transition-shadow rounded-full"
            *
          />
          <Button
            href="/om-oss/"
            type="secondary"
            size="lg"
            text="Om oss"
            *
            class="hover:bg-surface-muted transition-colors rounded-full"
            *
          />
        </div>
      </div>

      <div
        class="relative w-full h-full lg:min-h-[500px] flex items-center justify-center"
      >
        {/* Decorative backdrop for media */}
        <div
          class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent rounded-[var(--radius-card-lg)] transform rotate-2 scale-105 -z-10 opacity-70"
        >
        </div>

        <div
          class="relative w-full aspect-[4/3] rounded-[var(--radius-card)] overflow-hidden surface-card shadow-2xl transition-transform duration-500 hover:scale-[1.02]"
        >
          {
            data.image && !video.url && (
              <img
                src={data.image}
                alt={title ?? ""}
                class="object-cover w-full h-full"
                loading="lazy"
              />
            )
          }

          {
            video.url && (
              <figure class="w-full h-full wp-block-video m-0">
                <video
                  class="w-full h-full object-cover"
                  autoplay
                  loop
                  muted
                  src={video.url}
                  playsinline
                />
              </figure>
            )
          }

          {/* Subtle overlay to blend edges if needed */}
          <div
            class="absolute inset-0 ring-1 ring-inset ring-white/10 pointer-events-none rounded-[var(--radius-card)]"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
