---
interface Props {
	data?: {
		title?: string;
		description?: string;
		image?: string;
	};
}

const { data = {} } = Astro.props as Props;
---

<section class="section-spacing">
	<div class="site-container">
	<div class="surface-card-muted flex flex-col">
		{(data.title || data.description) && (
			<div class="section-intro section-intro--center section-intro--spaced section-intro--inset px-6 lg:px-10">
				{data.title && <h2>{data.title}</h2>}
				{data.description && <p class="text-lg prose-measure">{data.description}</p>}
			</div>
		)}
		<div class="section-after-intro grid gap-10 px-10 pb-10 lg:grid-cols-2 lg:px-20 lg:pb-20">
			<div class="lg:mr-20 flow">
				<slot />
			</div>
			<div class="overflow-hidden rounded-2xl">
				{data.image && <img src={data.image} alt={data.title ?? ''} class="object-cover w-full h-full" loading="lazy" />}
			</div>
		</div>
	</div>
	</div>
</section>
