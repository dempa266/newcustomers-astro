---
import { parseEncodedJson } from '../components/utils';

interface Testimonial {
	text?: string;
	image?: { url?: string; alt?: string };
	logo?: { url?: string; alt?: string };
}

interface Props {
	data?: {
		testimonials?: string;
	};
}

const { data = {} } = Astro.props as Props;
const testimonials = parseEncodedJson<Testimonial[]>(data.testimonials, []);
---

<section class="section-spacing">
	<div class="site-container">
		<div class="grid gap-8 lg:grid-cols-2 text-dark">
			{testimonials.map((testimonial) => (
				<div class="surface-card-muted flex flex-col overflow-hidden">
					{testimonial.image?.url && (
						<img
							class="w-full aspect-[16/9] object-cover"
							src={testimonial.image.url}
							alt={testimonial.image.alt ?? ''}
							width="800"
							height="400"
							loading="lazy"
						/>
					)}
					<p class="leading-relaxed px-6 pt-8 lg:px-12 text-lg text-center text-gray prose-measure mx-auto">{testimonial.text}</p>
					{testimonial.logo?.url && (
						<img
							class="w-40 h-auto mx-auto py-10"
							src={testimonial.logo.url}
							alt={testimonial.logo.alt ?? ''}
							width="200"
							height="200"
							loading="lazy"
						/>
					)}
				</div>
			))}
		</div>
	</div>
</section>
