---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import Button from '../components/Button.astro';
import { parseEncodedJson } from '../components/utils';

interface Testimonial {
	text?: string;
	image?: { url?: string; alt?: string };
	logo?: { url?: string; alt?: string };
}

interface Props {
	data?: {
		eyebrow?: string;
		title?: string;
		testimonials?: string;
		buttonText?: string;
		buttonLink?: string;
	};
}

const { data = {} } = Astro.props as Props;
const testimonials = parseEncodedJson<Testimonial[]>(data.testimonials, []);

const formatTestimonial = (fullText?: string) => {
	if (!fullText) return { quote: '', author: '', company: '' };
	const parts = fullText.split(' - ');
	if (parts.length > 1) {
		const authorFull = parts.pop()?.trim() || '';
		const quote = parts.join(' - ').trim();
		const authorParts = authorFull.split(' på ');
		return {
			quote,
			author: authorParts[0]?.trim() || '',
			company: authorParts[1]?.trim() || '',
		};
	}
	return { quote: fullText, author: '', company: '' };
};
---

<section class="section-spacing" aria-label={data.eyebrow ?? 'Recensioner'}>
	<div class="site-container">
		<div class="section-intro section-intro--center section-intro--spaced" data-reveal>
			{data.eyebrow && <SectionEyebrow text={data.eyebrow} center />}
			{data.title && <h2>{data.title}</h2>}
		</div>

		<div class="section-after-intro max-w-4xl mx-auto border-t border-black/6" data-reveal-children>
			{testimonials.map((testimonial, i) => {
				const { quote, author, company } = formatTestimonial(testimonial.text);
				return (
					<div class="py-10 border-b border-black/6">
						<div class="flex gap-5">
							<span class="shrink-0 font-[var(--font-heading)] text-base font-semibold leading-[1.12] text-primary tabular-nums">
								{String(i + 1).padStart(2, '0')}
							</span>
							<div>
								<blockquote class="m-0">
									<p class="text-foreground/82 leading-relaxed max-w-[58ch]">{quote}</p>
								</blockquote>
								<div class="mt-5 flex flex-wrap items-center gap-4">
									<div>
										{author && <p class="font-[var(--font-heading)] text-sm font-semibold text-foreground">{author}</p>}
										{company && <p class="text-sm text-foreground/44">{company}</p>}
									</div>
									{testimonial.logo?.url && (
										<img
											class="h-4 w-auto object-contain opacity-50 ml-auto"
											src={testimonial.logo.url}
											alt={testimonial.logo.alt ?? ''}
											width="80"
											height="16"
											loading="lazy"
										/>
									)}
								</div>
							</div>
						</div>
					</div>
				);
			})}
		</div>

		{data.buttonText && (
			<div class="mt-10 text-center">
				<Button type="secondary" size="md" href={data.buttonLink ?? '#'} text={data.buttonText} />
			</div>
		)}
	</div>
</section>
