---
import Button from '../components/Button.astro';

interface Props {
	data?: {
		title?: string;
		image?: string;
		buttontext?: string;
		buttonlink?: string;
	};
}

const { data = {} } = Astro.props as Props;
---

<section class="section-spacing">
	<div class="site-container">
		<div class="surface-card-dark grid overflow-hidden lg:grid-cols-2">
			<div class="flex aspect-[4/3] lg:aspect-auto">
				{data.image && <img src={data.image} alt={data.title ?? ''} class="object-cover w-full h-full" loading="lazy" />}
			</div>
			<div class="section-intro section-intro--center justify-center px-6 py-10 text-on-dark lg:px-16">
				{data.title && <h2 class="prose-measure">{data.title}</h2>}
				{data.buttontext && <Button href={data.buttonlink ?? '#'} type="transparent" size="lg" text={data.buttontext} />}
			</div>
		</div>
	</div>
</section>
