---
import Button from "../components/Button.astro";

interface Props {
  data?: {
    title?: string;
    image?: string;
    buttontext?: string;
    buttonlink?: string;
  };
}

const { data = {} } = Astro.props as Props;
---

<section class="section-spacing">
  <div class="site-container">
    <div
      class="relative overflow-hidden rounded-[var(--radius-card-lg)] bg-surface text-foreground shadow-2xl border border-border/50 group"
    >
      <div class="grid grid-cols-1 md:grid-cols-2">
        {/* Image Side */}
        <div
          class="relative min-h-[300px] md:min-h-[400px] overflow-hidden order-2 md:order-1"
        >
          {
            data.image && (
              <img
                src={data.image}
                alt={data.title ?? ""}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            )
          }
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent md:bg-gradient-to-r md:from-black/20 md:to-transparent"
          >
          </div>
        </div>

        {/* Content Side */}
        <div
          class="relative flex flex-col justify-center items-start p-10 sm:p-16 lg:p-20 order-1 md:order-2 bg-gradient-to-br from-surface to-surface-secondary"
        >
          {
            data.title && (
              <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-8 max-w-lg leading-tight">
                {data.title}
              </h2>
            )
          }
          {
            data.buttontext && (
              <Button
                href={data.buttonlink ?? "#"}
                type="primary"
                size="lg"
                text={data.buttontext}
              />
            )
          }

          {/* Subtle decorative element */}
          <div
            class="absolute bottom-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl rounded-tl-none translate-x-1/3 translate-y-1/3 pointer-events-none"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
