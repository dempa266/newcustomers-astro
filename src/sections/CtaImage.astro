---
import Button from '../components/Button.astro';

interface Props {
	data?: {
		title?: string;
		image?: string;
		buttontext?: string;
		buttonlink?: string;
	};
}

const { data = {} } = Astro.props as Props;

const contextType =
	data.buttonlink?.includes('/seo')
		? 'seo'
		: data.buttonlink?.includes('/affarsrapport')
			? 'report'
			: 'default';

const contextByType = {
	seo: {
		helper:
			'En praktisk kunskapsguide för bättre synlighet, starkare sökintention och fler kvalificerade affärer från Google.',
		points: ['Teknisk grund', 'Innehåll som rankar', 'Mätbar affärseffekt'],
		metricA: { label: 'Sökpotential', value: 'High' },
		metricB: { label: 'Intent Match', value: '88%' },
	},
	report: {
		helper:
			'Se hur vi kopplar trafik, leads och affärsutfall i en tydlig rapportmodell som gör beslut och prioritering enklare.',
		points: ['Trafik till lead', 'Lead till affär', 'Transparens per kanal'],
		metricA: { label: 'Datakvalitet', value: 'Live' },
		metricB: { label: 'Beslutsstöd', value: 'Klar' },
	},
	default: {
		helper:
			'Samlad kunskap i ett tydligt format så ni kan prioritera rätt insatser, snabbare fatta beslut och skapa stabil tillväxt.',
		points: ['Strategi', 'Genomförande', 'Uppföljning'],
		metricA: { label: 'Status', value: 'Aktiv' },
		metricB: { label: 'Signaler', value: 'Stabila' },
	},
} as const;

const context = contextByType[contextType];
---

<section class="section-spacing" aria-label="CTA">
	<div class="site-container">
		<div class="group relative overflow-hidden rounded-[3rem] border border-black/10 bg-[linear-gradient(165deg,#ffffff_0%,#f7f9fc_48%,#edf2f7_100%)] text-foreground shadow-[0_28px_82px_-58px_rgba(0,0,0,0.2)]">
			<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_18%,rgba(255,255,255,0.92),transparent_52%),radial-gradient(circle_at_84%_82%,rgba(100,116,139,0.13),transparent_45%)]"></div>
			<div class="pointer-events-none absolute inset-0 opacity-45 [background-image:linear-gradient(to_right,rgba(100,116,139,0.14)_1px,transparent_1px),linear-gradient(to_bottom,rgba(100,116,139,0.14)_1px,transparent_1px)] [background-size:44px_44px] [mask-image:linear-gradient(to_bottom,transparent_0%,black_24%,black_100%)]"></div>
			<div class="relative grid grid-cols-1 items-stretch md:grid-cols-[1fr_1.08fr]">
				<div class="relative order-2 min-h-[320px] overflow-hidden border-t border-black/8 md:order-1 md:min-h-[460px] md:border-t-0 md:border-r md:border-black/8">
					{data.image && (
						<img src={data.image} alt={data.title ?? ''} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
					)}
					<div class="absolute inset-0 bg-gradient-to-t from-black/30 via-black/8 to-transparent md:bg-gradient-to-r md:from-black/20 md:to-transparent"></div>
					<div class="absolute inset-x-5 bottom-5 rounded-2xl border border-white/25 bg-black/35 px-4 py-3 backdrop-blur-sm">
						<p class="type-micro-label text-white/72">Knowledge Preview</p>
						<div class="mt-2 grid grid-cols-2 gap-2">
							<div class="rounded-lg bg-white/14 px-3 py-2">
								<p class="type-micro-label text-white/68">{context.metricA.label}</p>
								<p class="mt-1 type-micro-value text-white">{context.metricA.value}</p>
							</div>
							<div class="rounded-lg bg-white/14 px-3 py-2">
								<p class="type-micro-label text-white/68">{context.metricB.label}</p>
								<p class="mt-1 type-micro-value text-white">{context.metricB.value}</p>
							</div>
						</div>
					</div>
				</div>

				<div class="relative order-1 flex flex-col justify-center p-8 sm:p-10 lg:p-12 md:order-2">
					<div class="section-intro max-w-[54ch]">
						{data.title && <h2 class="type-section-title max-w-[18ch]">{data.title}</h2>}
						<p class="type-section-lead text-foreground/66">{context.helper}</p>
					</div>

					<ul class="mt-7 grid list-none gap-2 pl-0 sm:grid-cols-3">
						{context.points.map((point) => (
							<li class="mb-0 rounded-xl border border-black/10 bg-white/82 px-3 py-2 text-sm text-foreground/72">
								<span class="type-micro-label text-slate-600">{point}</span>
							</li>
						))}
					</ul>

					{data.buttontext && (
						<div class="mt-9 flex flex-wrap items-center gap-4">
							<Button href={data.buttonlink ?? '#'} type="primary" size="lg" text={data.buttontext} class="text-sm tracking-[0.08em] uppercase" />
							<span class="type-meta-note text-foreground/48">Praktisk guide • konkret nytta</span>
						</div>
					)}

					<div class="mt-8 rounded-2xl border border-black/10 bg-white/82 px-4 py-4">
						<div class="mb-2 flex items-center justify-between">
							<p class="type-micro-label text-foreground/50">Signal trend</p>
							<p class="type-micro-label text-slate-600/90">Senaste 30 dagar</p>
						</div>
						<svg viewBox="0 0 320 84" class="h-16 w-full" fill="none" aria-hidden="true">
							<path d="M0 68H320" stroke="rgba(17,17,17,0.12)" stroke-width="1.5" />
							<path
								d="M12 58C34 56 48 52 68 46C88 40 100 32 120 30C140 28 156 33 176 36C198 39 214 34 234 28C254 22 272 16 308 14"
								stroke="rgba(100,116,139,0.82)"
								stroke-width="3"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
							<circle cx="308" cy="14" r="4.5" fill="rgba(100,116,139,0.9)" />
						</svg>
					</div>

					<div class="pointer-events-none absolute -bottom-28 -right-24 h-64 w-64 rounded-full bg-slate-400/14 blur-3xl"></div>
				</div>
			</div>
		</div>
	</div>
</section>
