---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { parseEncodedJson } from '../components/utils';

interface Stat {
	value?: string;
	label?: string;
	image?: { url?: string; alt?: string };
	stars?: number;
}

interface Props {
	data?: {
		eyebrow?: string;
		stats?: string;
	};
}

const { data = {} } = Astro.props as Props;
const stats = parseEncodedJson<Stat[]>(data.stats, []);
const cols = stats.length;
const colsClass: Record<number, string> = {
	2: 'md:grid-cols-2',
	3: 'md:grid-cols-3',
	4: 'md:grid-cols-4',
	5: 'md:grid-cols-5',
	6: 'md:grid-cols-6',
};
---

<section class="section-spacing-tight" aria-label={data.eyebrow ?? 'Statistik'}>
	<div class="site-container">
		{data.eyebrow && (
			<div class="max-w-4xl mx-auto" data-reveal>
				<SectionEyebrow text={data.eyebrow} center />
			</div>
		)}
		<div data-reveal-children class:list={[
			'max-w-4xl mx-auto grid grid-cols-2',
			data.eyebrow ? 'mt-5' : '',
			colsClass[cols] ?? 'md:grid-cols-4',
		]}>
			{stats.map((stat) => (
				<div class="py-8 flex flex-col items-center justify-center">
					{stat.image?.url && (
						<img
							src={stat.image.url}
							class="h-7 w-auto object-contain brightness-0 opacity-40"
							alt={stat.image.alt ?? ''}
							width="120"
							height="28"
						/>
					)}
					{stat.stars && stat.stars > 0 && (
						<div class="flex items-center gap-0.5 mt-2">
							{Array.from({ length: stat.stars }).map(() => (
								<img src="/star.svg" class="w-4 h-4 brightness-0 opacity-40" alt="Star" />
							))}
						</div>
					)}
					{stat.value && (
						<div class="font-[var(--font-heading)] text-[clamp(2.2rem,3.6vw,3rem)] font-bold leading-none tracking-tight text-foreground">
							{stat.value}
						</div>
					)}
					{stat.label && (
						<div class="type-micro-label mt-3 text-foreground/40">{stat.label}</div>
					)}
				</div>
			))}
		</div>
	</div>
</section>
