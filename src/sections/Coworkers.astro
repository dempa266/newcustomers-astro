---
import { parseEncodedJson } from '../components/utils';

interface Coworker {
	image?: { url?: string };
	name?: string;
	title?: string;
	phone?: string;
	email?: string;
	linkedin?: string;
}

interface Props {
	data?: {
		coworkers?: string;
	};
	compact?: boolean;
}

const { data = {}, compact = false } = Astro.props as Props;
const coworkers = parseEncodedJson<Coworker[]>(data.coworkers, []);
const sectionClass = compact ? '' : 'section-spacing';
---

<section class={sectionClass}>
	<div class="site-container-narrow">
		<div class="grid w-full gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
		{coworkers.map((coworker) => (
			<div class="surface-card-muted surface-card-interactive relative w-64 flex flex-col z-0 mx-auto p-3">
				{coworker.image?.url && (
					<div class="h-64 flex">
						<img
							class="mx-auto object-cover w-full sm:h-full rounded-2xl"
							src={coworker.image.url}
							width="640"
							height="480"
							alt={coworker.name ?? 'Coworker'}
							loading="lazy"
						/>
					</div>
				)}
				<div class="font-medium text-lg mt-3 px-1">{coworker.name}</div>
				{coworker.title && <div class="text-sm font-light text-muted mb-1 px-1">{coworker.title}</div>}
				{coworker.phone && <a href={`tel:${coworker.phone}`} class="text-base text-gray my-1 px-1 no-underline hover:text-primary">{coworker.phone}</a>}
				{coworker.email && <a href={`mailto:${coworker.email}`} class="text-base text-gray my-1 px-1 no-underline hover:text-primary">{coworker.email}</a>}
				{coworker.linkedin && (
					<a href={coworker.linkedin} target="_blank" rel="noreferrer">
						<img
							class="w-6 h-6 absolute bottom-0 right-0"
							src="https://wp.newcustomers.se/wp-content/uploads/2024/01/61109.png"
							width="100"
							height="100"
							alt="LinkedIn"
						/>
					</a>
				)}
			</div>
		))}
		</div>
	</div>
</section>
