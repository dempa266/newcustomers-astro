---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import Button from '../components/Button.astro';
import { parseEncodedJson } from '../components/utils';

interface Metric {
	value?: string;
	label?: string;
}

interface CaseStudy {
	title?: string;
	description?: string;
	metrics?: Metric[];
	tag?: string;
}

interface Props {
	data?: {
		eyebrow?: string;
		title?: string;
		description?: string;
		cases?: string;
		buttonText?: string;
		buttonLink?: string;
	};
}

const { data = {} } = Astro.props as Props;
const cases = parseEncodedJson<CaseStudy[]>(data.cases, []);
---

<section class="section-spacing" aria-label="Resultat">
	<div class="site-container">
		<div class="section-intro section-intro--center section-intro--spaced" data-reveal>
			{data.eyebrow && <SectionEyebrow text={data.eyebrow} center />}
			{data.title && <h2>{data.title}</h2>}
			{data.description && <p class="type-section-lead max-w-[62ch] mx-auto">{data.description}</p>}
		</div>

		<div class="section-after-intro results-grid">
			{cases.map((study) => (
				<article class="results-case" data-reveal>
					{study.tag && (
						<div class="type-micro-label text-primary mb-5">{study.tag}</div>
					)}

					{study.title && <h3 class="mb-3">{study.title}</h3>}
					{study.description && <p class="max-w-[50ch] leading-relaxed">{study.description}</p>}

					{study.metrics && study.metrics.length > 0 && (
						<div class="mt-8 pt-8 border-t border-black/6 flex flex-wrap gap-x-10 gap-y-5">
							{study.metrics.map((metric) => (
								<div>
									<div class="font-[var(--font-heading)] text-[clamp(1.8rem,3vw,2.4rem)] font-bold leading-none tracking-tight text-foreground">{metric.value}</div>
									<div class="type-micro-label mt-2 text-foreground/40">{metric.label}</div>
								</div>
							))}
						</div>
					)}
				</article>
			))}
		</div>

		{data.buttonText && (
			<div class="mt-12 text-center">
				<Button type="primary" size="lg" href={data.buttonLink ?? '#'} text={data.buttonText} />
			</div>
		)}
	</div>
</section>

<style>
	.results-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3.5rem;
	}

	@media (min-width: 1024px) {
		.results-grid {
			grid-template-columns: 1fr 1px 1fr;
			gap: 0;
			align-items: start;
		}

		.results-grid::after {
			content: '';
			grid-column: 2;
			grid-row: 1;
			align-self: stretch;
			background: color-mix(in oklab, var(--foreground) 8%, transparent);
		}

		.results-case:first-child {
			grid-column: 1;
			padding-right: 3.5rem;
		}

		.results-case:last-child {
			grid-column: 3;
			padding-left: 3.5rem;
		}
	}
</style>
