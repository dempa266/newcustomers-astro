---
import CompactContactForm from '../components/CompactContactForm.astro';

interface Props {
	data?: {
		title?: string;
		description?: string;
	};
}

const { data = {} } = Astro.props as Props;

const steps = [
	{
		number: '01',
		title: 'Kontaktstart',
		text: 'Skicka in ditt namn och telefonnummer.',
		motif: 'geometry',
	},
	{
		number: '02',
		title: 'Behovsanalys',
		text: 'Någon från oss tar kontakt och lyssnar av era behov och mål.',
		motif: 'laser',
	},
	{
		number: '03',
		title: 'Strategimöte',
		text: 'Rätt specialist sätter upp ett möte för att starta affärsanalysen.',
		motif: 'wave',
	},
	{
		number: '04',
		title: 'Konkret förslag',
		text: 'Ni får ett konkret förslag på hur vi skapar fler affärer.',
		motif: 'spark',
	},
];
---

<section class="section-spacing relative" aria-label="Process" data-protocol-root>
	<div class="mx-auto max-w-[82rem] rounded-[3rem] border border-black/10 bg-[linear-gradient(180deg,#ffffff_0%,#f6f8fb_100%)] px-4 py-14 text-foreground shadow-[0_30px_90px_-62px_rgba(0,0,0,0.14)] sm:px-8 lg:px-10 lg:py-20">
		<div class="site-container">
			{(data.title || data.description) && (
				<div class="section-intro section-intro--center section-intro--spaced mx-auto max-w-3xl">
					{data.title && <h2 class="type-section-title text-foreground">{data.title}</h2>}
					{data.description && <p class="type-section-lead text-foreground/72">{data.description}</p>}
				</div>
			)}

			<div class="relative mx-auto mt-10 max-w-6xl" data-protocol-rail>
				<div class="absolute bottom-0 left-4 top-0 w-px bg-black/12 md:left-1/2 md:-translate-x-1/2" data-protocol-line></div>

				<div class="space-y-6 md:space-y-8">
					{steps.map((step, index) => (
						<article class:list={['protocol-step relative md:flex', index % 2 === 0 ? 'md:justify-start' : 'md:justify-end']}>
							<span class="absolute left-4 top-8 h-3.5 w-3.5 -translate-x-1/2 rounded-full border border-primary/60 bg-white shadow-[0_0_0_4px_rgba(213,164,56,0.12)] md:left-1/2 md:top-14"></span>

							<div class="protocol-step-card flow ml-9 rounded-[2rem] border border-black/10 bg-white/96 p-6 shadow-[0_20px_56px_-44px_rgba(0,0,0,0.26)] md:ml-0 md:w-[calc(50%-2rem)] md:p-8">
								<div class="flex items-start justify-between gap-4">
									<div class="flow">
										<p class="type-micro-label text-foreground/58">STEP {step.number}</p>
										<h3 class="type-card-title text-foreground">{step.title}</h3>
									</div>
									<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-black/10 bg-[#f8fafc]">
										{step.motif === 'geometry' && (
											<div class="relative h-7 w-7">
												<div class="absolute inset-0 animate-[spin_12s_linear_infinite] rounded-[0.7rem] border border-primary/70"></div>
												<div class="absolute inset-1.5 animate-[spin_8s_linear_reverse_infinite] rounded-[0.45rem] border border-black/28"></div>
											</div>
										)}
										{step.motif === 'laser' && <span class="h-7 w-1 rounded-full bg-[linear-gradient(180deg,var(--primary),transparent)]"></span>}
										{step.motif === 'wave' && (
											<svg viewBox="0 0 48 22" class="h-6 w-8" fill="none" aria-hidden="true">
												<path d="M1 11C5 3 9 3 13 11C17 19 21 19 25 11C29 3 33 3 37 11C41 19 45 19 47 11" stroke="rgba(213,164,56,0.9)" stroke-width="2" />
											</svg>
										)}
										{step.motif === 'spark' && <span class="h-5 w-5 rounded-full bg-primary/70 shadow-[0_0_18px_rgba(213,164,56,0.6)]"></span>}
									</div>
								</div>
								<p class="type-card-body text-foreground/78">{step.text}</p>
							</div>
						</article>
					))}
				</div>
			</div>

			<div class="mx-auto mt-16 max-w-xl rounded-[2rem] border border-black/10 bg-white p-6 shadow-2xl sm:p-8" id="kontakt">
				<CompactContactForm />
			</div>
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const root = document.querySelector('[data-protocol-root]');
	if (root) {
		const ctx = gsap.context(() => {
			gsap.fromTo(
				'.protocol-step-card',
				{ y: 36, opacity: 0 },
				{
					y: 0,
					opacity: 1,
					duration: 0.9,
					stagger: 0.15,
					ease: 'power3.out',
					scrollTrigger: { trigger: root, start: 'top 78%' },
				},
			);

			gsap.fromTo(
				'[data-protocol-line]',
				{ scaleY: 0, transformOrigin: 'top center' },
				{
					scaleY: 1,
					ease: 'power2.inOut',
					scrollTrigger: {
						trigger: root,
						start: 'top 72%',
						end: 'bottom 70%',
						scrub: true,
					},
				},
			);
		}, root);

		window.addEventListener(
			'pagehide',
			() => {
				ctx.revert();
			},
			{ once: true },
		);
	}
</script>
