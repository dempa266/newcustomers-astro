---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { parseEncodedJson } from '../components/utils';

interface PainPoint {
	title?: string;
	description?: string;
}

interface Props {
	data?: {
		eyebrow?: string;
		title?: string;
		description?: string;
		painPoints?: string;
		transitionText?: string;
	};
}

const { data = {} } = Astro.props as Props;
const painPoints = parseEncodedJson<PainPoint[]>(data.painPoints, []);
---

<section class="section-spacing" aria-label="Utmaningar">
	<div class="site-container">
		<div class="section-intro section-intro--center section-intro--spaced" data-reveal>
			{data.eyebrow && <SectionEyebrow text={data.eyebrow} center />}
			{data.title && <h2>{data.title}</h2>}
			{data.description && <p class="type-section-lead max-w-[62ch] mx-auto">{data.description}</p>}
		</div>

		<div class="section-after-intro grid gap-x-16 gap-y-0 grid-cols-1 md:grid-cols-2 max-w-4xl mx-auto" data-reveal-children>
			{painPoints.map((point, i) => (
				<div class="flex gap-5 py-8 border-b border-black/6">
					<span class="shrink-0 font-[var(--font-heading)] text-base font-semibold leading-[1.12] text-primary tabular-nums">
						{String(i + 1).padStart(2, '0')}
					</span>
					<div class="flow">
						{point.title && <h4 class="text-foreground">{point.title}</h4>}
						{point.description && <p class="leading-relaxed">{point.description}</p>}
					</div>
				</div>
			))}
		</div>

		{data.transitionText && (
			<p data-reveal class="cinematic-serif pt-8 max-w-[42ch] text-3xl leading-snug text-gray" style="margin-inline: auto; text-align: center;">
				{data.transitionText}
			</p>
		)}
	</div>
</section>
