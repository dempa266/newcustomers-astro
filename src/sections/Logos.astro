---
import { parseEncodedJson } from '../components/utils';

interface Logo {
	icon?: {
		url?: string;
	};
}

interface Props {
	data?: {
		logos?: string;
	};
}

const { data = {} } = Astro.props as Props;
const logos = parseEncodedJson<Logo[]>(data.logos, []);
---

<section class="section-spacing-tight">
	<div class="site-container">
		<div class="surface-card-dark px-6 py-7 lg:px-8 lg:py-8">
			<div class="section-intro section-intro--center section-intro--spaced">
				<p class="section-eyebrow section-eyebrow--on-dark">Betrodd av ledande varumärken</p>
			</div>
			<div class="grid w-full gap-8 grid-cols-2 sm:grid-cols-4 lg:grid-cols-7">
			{logos.map((logo) => (
				<div class="mx-auto flex opacity-90 hover:opacity-100">
					{logo.icon?.url && (
						<img class="w-24 my-auto grayscale contrast-150 brightness-95" src={logo.icon.url} alt="Logo" width="256" height="256" loading="lazy" />
					)}
				</div>
			))}
			</div>
		</div>
	</div>
</section>
