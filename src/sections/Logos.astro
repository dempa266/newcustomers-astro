---
import { parseEncodedJson } from '../components/utils';

interface Logo {
	icon?: {
		url?: string;
	};
}

interface Props {
	data?: {
		logos?: string;
	};
}

const { data = {} } = Astro.props as Props;
const logos = parseEncodedJson<Logo[]>(data.logos, []);
---

<section class="section-spacing-tight">
	<div class="site-container">
		<div class="grid w-full gap-10 grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 bg-gray p-6 rounded-2xl">
		{logos.map((logo) => (
			<div class="mx-auto flex">
				{logo.icon?.url && (
					<img class="w-24 my-auto" src={logo.icon.url} alt="Logo" width="256" height="256" loading="lazy" />
				)}
			</div>
		))}
		</div>
	</div>
</section>
