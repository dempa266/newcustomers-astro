---
import { parseEncodedJson } from "../components/utils";

interface PageLink {
  text?: string;
  url?: string;
  icon?: {
    url?: string;
  };
}

interface Props {
  data?: {
    links?: string;
  };
}

const { data = {} } = Astro.props as Props;
const links = parseEncodedJson<PageLink[]>(data.links, []);
---

<section class="section-spacing relative z-10 -mt-8">
  <div class="site-container">
    <ul class="grid w-full list-none gap-6 lg:gap-8 pl-0 md:grid-cols-3">
      {
        links.map((link) => (
          <li class="mb-0">
            <a
              href={link.url ?? "#kontakt"}
              class="surface-card group flex h-full flex-col p-6 sm:p-8 no-underline transition-all duration-300 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 hover:bg-surface/50"
            >
              <div class="mb-8 flex items-center justify-between gap-4">
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-primary/5 p-3 text-primary transition-colors group-hover:bg-primary/10">
                  {link.icon?.url && (
                    <img
                      class="h-full w-full object-contain drop-shadow-sm transition-transform duration-300 group-hover:scale-110"
                      src={link.icon.url}
                      alt={`Illustration: ${link.text ?? "Länk"}`}
                      width="144"
                      height="144"
                      loading="lazy"
                    />
                  )}
                </div>
              </div>

              <h3 class="text-xl font-semibold leading-tight text-foreground group-hover:text-primary transition-colors">
                {link.text}
              </h3>

              <div class="mt-6 mt-auto pt-6 border-t border-border/40">
                <span class="inline-flex items-center gap-2 text-sm font-semibold text-primary">
                  Starta här
                  <svg
                    class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M4.75 10H15.25M10.75 5.5L15.25 10L10.75 14.5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
