---
import Button from '../components/Button.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
	h1?: string;
	description?: string;
	data?: {
		title?: string;
		description?: string;
		image?: string;
		noBackgroundImage?: boolean;
		logos?: Array<{
			icon?: {
				url?: string;
				alt?: string;
			};
			name?: string;
		}>;
		primaryCta?: { text?: string; href?: string };
		secondaryCta?: { text?: string; href?: string };
	};
}

const { h1, description, data = {} } = Astro.props as Props;
const title = data.title ?? h1;
const text = data.description ?? description;
const noBackgroundImage = data.noBackgroundImage ?? true;
const heroImage =
	data.image ??
	'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=2200&q=80';
const logoCloud = data.logos ?? [];
const hasLogoCloud = logoCloud.length > 0;

const primaryCta = data.primaryCta ?? { text: 'Boka möte', href: '/kontakt/' };
const secondaryCta = data.secondaryCta ?? { text: 'Om oss', href: '/om-oss/' };

const splitToken = ' och ';
let heroLineOne = title ?? '';
let heroLineTwo = '';

if (title && title.includes(splitToken)) {
	const [first, ...rest] = title.split(splitToken);
	heroLineOne = first.trim();
	heroLineTwo = `och ${rest.join(splitToken).trim()}`;
}
---

<section
	id="hero"
	aria-label="Hero"
	class="relative -mt-[8rem] flex items-end overflow-hidden border-b border-black/10 pb-16 pt-44 md:pb-24 md:pt-52"
	data-subhero-root
>
	{!noBackgroundImage && (
		<img src={heroImage} alt={title ?? 'Hero image'} class="absolute inset-0 h-full w-full object-cover" loading="eager" />
	)}

	<div
		class:list={[
			'absolute inset-0',
			noBackgroundImage
				? 'bg-[linear-gradient(165deg,#ffffff_0%,#f7f9fc_44%,#eef2f7_100%)]'
				: 'bg-[linear-gradient(180deg,rgba(9,9,14,0.25)_0%,rgba(9,9,14,0.55)_54%,rgba(9,9,14,0.84)_100%)]',
		]}
	></div>

	{noBackgroundImage && (
		<>
			<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_20%,rgba(148,163,184,0.24),transparent_40%),radial-gradient(circle_at_88%_76%,rgba(100,116,139,0.16),transparent_44%)]"></div>
			<div class="pointer-events-none absolute inset-0 opacity-56 [background-image:linear-gradient(to_right,rgba(100,116,139,0.16)_1px,transparent_1px),linear-gradient(to_bottom,rgba(100,116,139,0.16)_1px,transparent_1px)] [background-size:46px_46px] [mask-image:linear-gradient(to_bottom,transparent_0%,black_12%,black_100%)]"></div>
			<div class="pointer-events-none absolute -right-36 top-16 h-[28rem] w-[28rem] rounded-full border border-slate-500/24 bg-[radial-gradient(circle,rgba(255,255,255,0.66),rgba(255,255,255,0)_70%)]"></div>
		</>
	)}

	<div class="site-container relative z-10 w-full">
		<div class="flex flex-col">
			<div class="w-full max-w-3xl">
				{title && (
					<h1
						class:list={[
							'subhero-reveal text-[clamp(2.25rem,5.8vw,5rem)] font-semibold leading-[0.9] tracking-[-0.036em]',
							noBackgroundImage ? 'text-foreground' : 'text-white',
						]}
					>
						<span class="block">{heroLineOne}</span>
						{heroLineTwo && (
							<span class:list={['cinematic-serif mt-3 block text-[0.92em] font-semibold', noBackgroundImage ? 'text-foreground/88' : 'text-white/88']} data-typewriter={heroLineTwo}>
								<span class="typewriter-text" aria-hidden="true"></span>
								<span class="typewriter-placeholder invisible" aria-hidden="true">{heroLineTwo}</span>
								<span class="typewriter-cursor" aria-hidden="true"></span>
								<span class="sr-only">{heroLineTwo}</span>
							</span>
						)}
					</h1>
				)}
				{text && (
					<p class:list={['subhero-reveal type-section-lead mt-10 max-w-[58ch]', noBackgroundImage ? 'text-foreground/80' : 'text-white/80']}>
						{text}
					</p>
				)}

				<div class:list={['subhero-reveal flex flex-wrap items-center gap-3.5 sm:gap-4', text ? 'mt-8' : 'mt-10']}>
					<Button href={primaryCta.href ?? '/kontakt/'} type="primary" size="md" text={primaryCta.text ?? 'Boka möte'} class="text-sm tracking-[0.08em] uppercase" />
					<Button
						href={secondaryCta.href ?? '/om-oss/'}
						type={noBackgroundImage ? 'secondary' : 'transparent'}
						size="md"
						text={secondaryCta.text ?? 'Om oss'}
						class="text-sm tracking-[0.08em] uppercase"
					/>
				</div>
			</div>
			{hasLogoCloud && (
				<div
					class:list={[
						'subhero-reveal w-full mt-10 px-0 py-2 md:mt-14 md:py-3',
						noBackgroundImage ? '' : 'text-white',
					]}
				>
					<div class="grid grid-cols-2 gap-x-7 gap-y-5 sm:grid-cols-3 lg:grid-cols-7">
						{logoCloud.map((logo) => (
							<div class="mx-auto flex h-10 w-full items-center justify-center">
								{logo.icon?.url && (
									<img
										class:list={[
											'max-h-7 max-w-full object-contain',
											noBackgroundImage ? 'brightness-0 contrast-200 opacity-76' : 'grayscale opacity-82',
										]}
										src={logo.icon.url}
										alt={logo.icon.alt ?? logo.name ?? 'Kundlogotyp'}
										width="220"
										height="80"
										loading="eager"
									/>
								)}
							</div>
						))}
					</div>
				</div>
			)}
		</div>
	</div>
</section>

<div class="site-container py-4">
	<Breadcrumbs />
</div>

<style>
	[data-typewriter] {
		position: relative;
	}

	.typewriter-text {
		position: absolute;
		left: 0;
		top: 0;
	}

	.typewriter-placeholder {
		user-select: none;
		pointer-events: none;
	}

	/* Hide placeholder once typing is done */
	[data-typewriter].is-done .typewriter-placeholder {
		display: none;
	}

	[data-typewriter].is-done .typewriter-text {
		position: static;
	}

	.typewriter-cursor {
		display: inline-block;
		width: 0.05em;
		height: 0.82em;
		vertical-align: -0.04em;
		margin-left: 0.02em;
		background: currentColor;
		border-radius: 1px;
		opacity: 0;
		transition: opacity 0.15s;
	}

	.typewriter-cursor.is-typing {
		opacity: 0.8;
		animation: cursor-blink 0.72s ease-in-out infinite;
	}

	.typewriter-cursor.is-done {
		animation: cursor-fade 0.72s ease-in-out 3;
		animation-fill-mode: forwards;
	}

	@keyframes cursor-blink {
		0%, 100% { opacity: 0.8; }
		50% { opacity: 0; }
	}

	@keyframes cursor-fade {
		0%, 100% { opacity: 0.6; }
		50% { opacity: 0; }
	}

	@media (prefers-reduced-motion: reduce) {
		.typewriter-cursor { display: none; }
		.typewriter-placeholder { display: none !important; }
		.typewriter-text { position: static !important; }
	}
</style>

<script>
	import gsap from 'gsap';

	const heroRoot = document.querySelector('[data-subhero-root]');
	if (heroRoot) {
		const reveals = heroRoot.querySelectorAll('.subhero-reveal');
		const revealDuration = 0.08 + (reveals.length * 0.04) + 0.55;

		const ctx = gsap.context(() => {
			gsap.fromTo(
				reveals,
				{ y: 12, opacity: 0 },
				{ y: 0, opacity: 1, duration: 0.55, stagger: 0.04, ease: 'power2.out', delay: 0.08 },
			);
		}, heroRoot);

		// Typewriter effect
		const el = heroRoot.querySelector<HTMLElement>('[data-typewriter]');
		if (el && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			const fullText = el.dataset.typewriter || '';
			const textEl = el.querySelector<HTMLElement>('.typewriter-text');
			const cursorEl = el.querySelector<HTMLElement>('.typewriter-cursor');

			if (textEl && cursorEl && fullText) {
				let i = 0;
				const baseSpeed = 38;

				// Variable delay per character — slight randomness for natural feel,
				// slower on spaces and after punctuation
				function nextDelay(): number {
					const char = fullText[i];
					const jitter = Math.random() * 28 - 14; // ±14ms
					if (char === ' ') return baseSpeed + 30 + jitter;
					if (',.:;!?'.includes(char)) return baseSpeed + 80 + jitter;
					return baseSpeed + jitter;
				}

				function typeNext() {
					i++;
					textEl.textContent = fullText.slice(0, i);
					if (i < fullText.length) {
						setTimeout(typeNext, nextDelay());
					} else {
						// Done
						el.classList.add('is-done');
						cursorEl.classList.remove('is-typing');
						cursorEl.classList.add('is-done');
						setTimeout(() => { cursorEl.style.display = 'none'; }, 2500);
					}
				}

				// Start after reveal animation completes
				setTimeout(() => {
					cursorEl.classList.add('is-typing');
					setTimeout(typeNext, 300); // brief pause before first character
				}, revealDuration * 1000 + 100);
			}
		} else if (el) {
			// Reduced motion: show immediately
			const textEl = el.querySelector<HTMLElement>('.typewriter-text');
			if (textEl) textEl.textContent = el.dataset.typewriter || '';
			el.classList.add('is-done');
		}

		window.addEventListener('pagehide', () => ctx.revert(), { once: true });
	}
</script>
