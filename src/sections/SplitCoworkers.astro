---
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { parseEncodedJson } from '../components/utils';

interface Coworker {
	image?: { url?: string };
	name?: string;
	title?: string;
	phone?: string;
	email?: string;
}

interface Props {
	data?: {
		eyebrow?: string;
		title?: string;
		description?: string;
		coworkers?: string;
	};
}

const { data = {} } = Astro.props as Props;
const coworkers = parseEncodedJson<Coworker[]>(data.coworkers, []);
---

<section class="section-spacing" aria-label="Teamet">
	<div class="site-container">
		<div class="section-intro section-intro--spaced" data-reveal>
			{data.eyebrow && <SectionEyebrow text={data.eyebrow} />}
			{data.title && <h2>{data.title}</h2>}
			{data.description && <p class="type-section-lead prose-measure">{data.description}</p>}
		</div>

		<div class="section-after-intro grid items-start gap-12 lg:grid-cols-[1.1fr_0.9fr]">
			<div class="coworkers-prose" data-reveal>
				<slot />
			</div>

			<div class="flex flex-col gap-0 border-t border-black/6" data-reveal-children>
				{coworkers.map((coworker) => (
					<div class="group flex gap-5 py-6 border-b border-black/6 sm:gap-6">
						<div class="coworker-image-wrap shrink-0">
							{coworker.image?.url ? (
								<img
									src={coworker.image.url}
									alt={coworker.name ?? ''}
									class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
									loading="lazy"
								/>
							) : (
								<div class="h-full w-full bg-black/[0.04]"></div>
							)}
						</div>
						<div class="flex flex-col justify-center">
							<h3 class="text-foreground" style="font-size: clamp(1.1rem, 1.03rem + 0.34vw, 1.34rem); letter-spacing: -0.012em; line-height: 1.28; font-weight: 600;">{coworker.name}</h3>
							<p class="mt-1 text-xs uppercase tracking-[0.1em] text-foreground/50">{coworker.title}</p>
							<div class="mt-3 flex flex-wrap gap-x-5 gap-y-1">
								{coworker.phone && (
									<a href={`tel:${coworker.phone}`} class="micro-link text-sm text-foreground/72 hover:text-primary no-underline">
										{coworker.phone}
									</a>
								)}
								{coworker.email && (
									<a href={`mailto:${coworker.email}`} class="micro-link text-sm text-foreground/72 hover:text-primary no-underline">
										{coworker.email}
									</a>
								)}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.coworkers-prose {
		border-top: 1px solid color-mix(in oklab, var(--foreground) 6%, transparent);
		padding-top: clamp(1.5rem, 2.5vw, 2rem);
	}

	.coworkers-prose :global(h3) {
		padding-top: 1.5rem;
	}

	.coworkers-prose :global(h3:first-child) {
		padding-top: 0;
	}

	.coworkers-prose :global(p) {
		margin-top: 0.5rem;
	}

	.coworker-image-wrap {
		width: 5.5rem;
		height: 5.5rem;
		border-radius: 1rem;
		overflow: hidden;
		background: color-mix(in oklab, var(--foreground) 3%, transparent);
	}

	@media (min-width: 640px) {
		.coworker-image-wrap {
			width: 6.5rem;
			height: 6.5rem;
		}
	}
</style>

