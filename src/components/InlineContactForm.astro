---
const fieldClassName =
	'field h-11 w-full rounded-xl border border-white/24 bg-white/8 px-3.5 text-sm text-white placeholder:text-white/55 outline-none transition focus:border-primary/65 focus:ring-2 focus:ring-primary/35';
const submitClassName =
	'button button--primary inline-flex h-11 items-center justify-center rounded-[var(--radius-button)] border border-transparent bg-primary px-8 text-sm font-semibold tracking-[0.08em] text-dark uppercase shadow-[0_12px_24px_-16px_rgba(213,164,56,0.75)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-surface-dark';
---

<div data-contact-form-include>
	<p class="mb-4 hidden rounded-lg border border-emerald-400/40 bg-emerald-500/12 px-4 py-3 text-sm font-medium text-emerald-100" data-success></p>

	<form action="#" method="POST" class="pt-4" data-form>
		<div class="space-y-3">
			<input type="text" name="name" autoComplete="name" placeholder="Namn" aria-label="Namn" class={fieldClassName} required />
			<input type="tel" name="phone" autoComplete="tel" placeholder="Telefon" aria-label="Telefon" class={fieldClassName} required />
			<input type="email" name="email" autoComplete="email" placeholder="E-post" aria-label="E-post" class={fieldClassName} />
			<input type="text" name="company" autoComplete="organization" placeholder="Företag" aria-label="Företag" class={fieldClassName} />

			<div class="pt-1">
				<button type="submit" class={submitClassName}>Skicka</button>
			</div>

			<label for="gdpr-include" class="flex items-start gap-3 rounded-xl border border-white/20 bg-white/5 px-3 py-3 text-sm leading-relaxed text-white/76">
				<input id="gdpr-include" name="gdpr" type="checkbox" class="mt-1 h-4 w-4 rounded border-white/35 accent-primary" />
				<span>
					Genom att skicka detta meddelande godkänner du att vi lagrar och hanterar dina personuppgifter i enlighet med vår
					<a href="/integritetspolicy/" class="font-semibold text-primary hover:text-primary-dark">integritetspolicy</a>.
				</span>
			</label>
		</div>

		<p class="mt-4 hidden rounded-lg border border-red-400/40 bg-red-500/15 px-4 py-3 text-sm font-medium text-red-100" data-error></p>
	</form>
</div>

<script is:inline>
	document.querySelectorAll('[data-contact-form-include]').forEach((root) => {
		if (root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const form = root.querySelector('[data-form]');
		const success = root.querySelector('[data-success]');
		const error = root.querySelector('[data-error]');

		if (!form || !success || !error) return;

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			error.textContent = '';
			error.classList.add('hidden');

			const gdpr = form.querySelector('[name="gdpr"]');
			if (!(gdpr instanceof HTMLInputElement) || !gdpr.checked) {
				error.textContent = 'Du behöver godkänna vår integritetspolicy innan du kan skicka meddelandet.';
				error.classList.remove('hidden');
				return;
			}

			const target = event.currentTarget;
			const formData = new FormData();
			formData.append('cc_name', target.elements.name?.value || '');
			formData.append('cc_email', target.elements.email?.value || '');
			formData.append('cc_phone', target.elements.phone?.value || '');
			formData.append('cc_company', target.elements.company?.value || '');
			formData.append('apiKey', '6321a3ced5af44fcd7338ac0');

			document.cookie.split('; ').forEach((cookie) => {
				const [key, value] = cookie.split('=');
				if (key === '_cc' && value) formData.append('cookie', value);
			});

			try {
				await fetch('https://api.customerconnect.se/submissions', {
					method: 'POST',
					body: formData,
				});
				success.textContent = 'Tack för ditt meddelande!';
				success.classList.remove('hidden');
				form.classList.add('hidden');
				target.reset();
			} catch {
				error.textContent = 'Något gick fel. Försök igen.';
				error.classList.remove('hidden');
			}
		});
	});
</script>
