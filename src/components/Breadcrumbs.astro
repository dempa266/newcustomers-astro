---
interface Breadcrumb {
	url: string;
	text: string;
}

interface Props {
	breadcrumbs?: Breadcrumb[];
}

const slugLabelMap: Record<string, string> = {
	seo: 'SEO',
	ads: 'Google Ads',
	sem: 'SEM',
	byra: 'Byrå',
	konsult: 'Konsult',
	'e-handel': 'E-handel',
	pris: 'Pris',
	stockholm: 'Stockholm',
	goteborg: 'Göteborg',
	malmo: 'Malmö',
	'om-oss': 'Om oss',
	kontakt: 'Kontakt',
	recensioner: 'Recensioner',
	integritetspolicy: 'Integritetspolicy',
	artiklar: 'Artiklar',
};

function toLabel(segment: string): string {
	const normalized = decodeURIComponent(segment).toLowerCase();
	const mapped = slugLabelMap[normalized];
	if (mapped) return mapped;
	return normalized
		.split('-')
		.filter(Boolean)
		.map((part) => part.charAt(0).toUpperCase() + part.slice(1))
		.join(' ');
}

function generateBreadcrumbs(pathname: string): Breadcrumb[] {
	if (pathname === '/') return [];
	const segments = pathname.split('/').filter(Boolean);
	const items: Breadcrumb[] = [{ url: '/', text: 'Hem' }];
	let currentPath = '';
	for (const segment of segments) {
		currentPath += `/${segment}`;
		items.push({ url: `${currentPath}/`, text: toLabel(segment) });
	}
	return items;
}

const { breadcrumbs: propBreadcrumbs } = Astro.props as Props;
const breadcrumbs = propBreadcrumbs ?? generateBreadcrumbs(Astro.url.pathname);
const site = Astro.site ?? new URL('http://localhost:4321');

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbs.map((breadcrumb, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: breadcrumb.text,
		item: new URL(breadcrumb.url, site).toString(),
	})),
};
---

{breadcrumbs.length > 0 && (
	<nav aria-label="Breadcrumb">
		<ol class="flex mx-0 px-0 list-none text-muted gap-2">
			{breadcrumbs.map((breadcrumb, index) => (
				<li class="my-0 flex items-center gap-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					{index === breadcrumbs.length - 1 ? (
						<span class="text-sm" itemprop="name">{breadcrumb.text}</span>
					) : (
						<a itemprop="item" href={breadcrumb.url} class="text-muted text-sm hover:text-primary transition">
							<span itemprop="name">{breadcrumb.text}</span>
						</a>
					)}
					<meta itemprop="position" content={(index + 1).toString()} />
					{index < breadcrumbs.length - 1 && <span aria-hidden="true" class="text-grayLight text-sm">/</span>}
				</li>
			))}
		</ol>
	</nav>
)}

{breadcrumbs.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>}
