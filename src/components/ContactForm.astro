---
import { Button, Checkbox, Input, TextArea } from '@heroui/react';
---

<section id="kontakt" class="section-spacing bg-gray-light" data-contact-form>
	<div class="site-container">
		<div class="grid gap-16 lg:grid-cols-2 sm:gap-y-20 lg:flex-row">
			<div>
				<h2>Kontakta oss</h2>
				<p class="mt-3 text-lg leading-6 text-gray">
					Varmt välkommen till oss på new customers. Vi har specialiserat oss på att skapa mer trafik till din webb, få ut mer affärer från webben och uppgradera dina kunders kundresa.
				</p>
				<dl class="mt-8 text-base text-gray grid grid-cols-2">
					<dt class="sr-only">Stockholm Address</dt>
					<dd>
						<div class="flex h-10 font-semibold"><span class="w-6 h-6 mt-1 text-primary">📍</span><div class="my-auto ml-1">Stockholm</div></div>
						<div>Kungsgatan 9</div>
						<div>111 43 Stockholm</div>
					</dd>
					<dt class="sr-only">Göteborg Address</dt>
					<dd>
						<div class="flex h-10 font-semibold"><span class="w-6 h-6 mt-1 text-primary">📍</span><div class="my-auto ml-1">Göteborg</div></div>
						<div>Kungsportsavenyn 21</div>
						<div>411 36 Göteborg</div>
					</dd>
					<div class="mt-6 space-y-3">
						<dt class="sr-only">Phone number</dt>
						<dd class="flex"><span class="flex-shrink-0 w-6 h-6 text-gray">📞</span><a href="tel:0703877177" class="ml-3 text-gray">070 387 71 77</a></dd>
						<dt class="sr-only">Email</dt>
						<dd class="flex"><span class="flex-shrink-0 w-6 h-6 text-gray">✉️</span><a href="mailto:info@newcustomers.se" class="ml-3 text-gray">info@newcustomers.se</a></dd>
					</div>
				</dl>
				<p class="mt-6 text-base text-gray">
					Letar du efter våra medarbetare?
					<a href="/om-oss/" class="font-medium text-gray-700 underline">Hitta dem här</a>.
				</p>
			</div>
			<div>
				<p class="text-primary font-bold text-center my-auto hidden" data-success></p>
				<form action="#" method="POST" class="lg:flex-auto" data-form>
					<div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
						<div>
							<label for="cf-name" class="block text-sm leading-6 text-gray">Namn</label>
							<div class="mt-2.5">
								<Input
									id="cf-name"
									type="text"
									name="name"
									aria-label="Namn"
									autoComplete="name"
									className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
								/>
							</div>
						</div>
						<div>
							<label for="cf-phone" class="block text-sm leading-6 text-gray">Telefon</label>
							<div class="mt-2.5">
								<Input
									id="cf-phone"
									type="text"
									name="phone"
									aria-label="Telefon"
									autoComplete="phone"
									className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
								/>
							</div>
						</div>
						<div>
							<label for="cf-email" class="block text-sm leading-6 text-gray">E-post</label>
							<div class="mt-2.5">
								<Input
									id="cf-email"
									type="text"
									name="email"
									aria-label="E-post"
									className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
								/>
							</div>
						</div>
						<div>
							<label for="cf-website" class="block text-sm leading-6 text-gray">Hemsida</label>
							<div class="mt-2.5">
								<Input
									id="cf-website"
									type="text"
									name="website"
									aria-label="Hemsida"
									className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
								/>
							</div>
						</div>
						<div class="sm:col-span-2">
							<label for="cf-message" class="block text-sm leading-6 text-gray">Meddelande</label>
							<div class="mt-2.5">
								<TextArea
									id="cf-message"
									name="message"
									rows={4}
									aria-label="Meddelande"
									className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6"
								/>
							</div>
						</div>
					</div>
					<div class="mt-10">
						<Button
							type="submit"
							className="block w-full rounded-md bg-primary px-3.5 py-2.5 text-center text-sm text-black shadow-sm hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
						>
							Skicka meddelande
						</Button>
					</div>
					<div class="mt-5 space-x-2">
						<Checkbox id="cf-gdpr" name="gdpr" className="text-sm leading-6 text-gray">
							Genom att skicka detta meddelande godkänner du att vi lagrar och hanterar dina personuppgifter i enlighet med vår
							<a href="/integritetspolicy/" class="text-primary">integritetspolicy</a>.
						</Checkbox>
					</div>
					<p class="text-red-500 hidden" data-error></p>
				</form>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	document.querySelectorAll('[data-contact-form]').forEach((root) => {
		if (root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const form = root.querySelector('[data-form]');
		const success = root.querySelector('[data-success]');
		const error = root.querySelector('[data-error]');

		if (!form || !success || !error) return;

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			error.textContent = '';
			error.classList.add('hidden');

			const gdpr = form.querySelector('[name="gdpr"]');
			if (!(gdpr instanceof HTMLInputElement) || !gdpr.checked) {
				error.textContent = 'Du behöver godkänna vår integritetspolicy innan du kan skicka meddelandet.';
				error.classList.remove('hidden');
				return;
			}

			const target = event.currentTarget;
			const formData = new FormData();
			formData.append('cc_name', target.elements.name?.value || '');
			formData.append('cc_email', target.elements.email?.value || '');
			formData.append('cc_phone', target.elements.phone?.value || '');
			formData.append('cc_website', target.elements.website?.value || '');
			formData.append('cc_message', target.elements.message?.value || '');
			formData.append('apiKey', '6321a3ced5af44fcd7338ac0');

			document.cookie.split('; ').forEach((cookie) => {
				const [key, value] = cookie.split('=');
				if (key === '_cc' && value) formData.append('cookie', value);
			});

			try {
				await fetch('https://api.customerconnect.se/submissions', {
					method: 'POST',
					body: formData,
				});
				success.textContent = 'Tack för ditt meddelande!';
				success.classList.remove('hidden');
				form.classList.add('hidden');
				target.reset();
			} catch {
				error.textContent = 'Något gick fel. Försök igen.';
				error.classList.remove('hidden');
			}
		});
	});
</script>
