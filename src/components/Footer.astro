---
import { footerNavigation } from '../data/navigation';
---

<footer class="mt-20 border-t border-white/8 bg-[linear-gradient(180deg,#15151f_0%,#111119_100%)] text-white/90" aria-labelledby="footer-heading">
	<h2 id="footer-heading" class="sr-only">Footer</h2>
	<div class="site-container py-14">
		<div class="xl:grid xl:grid-cols-3 xl:gap-8">
			<div class="flex flex-col items-center space-y-8 lg:items-start">
				<a href="/">
					<img src="/newcustomers.svg" alt="Logo" width="240" height="36" class="h-12 brightness-0 invert" />
				</a>
				<div class="w-full max-w-sm">
					<p class="type-micro-label mb-4 text-white/32 text-center lg:text-left">Utmärkelser</p>
					<div class="grid grid-cols-3 items-center gap-4">
						<img src="/ntc.png" alt="NTC" width="650" height="148" class="h-12 w-full object-contain brightness-0 invert opacity-40" />
						<img src="/SIGILL_SKOLD_VANSTER_STOR_VIT_TEXT.png" alt="Sigill" width="650" height="148" class="h-12 w-full object-contain brightness-0 invert opacity-40" />
						<img src="/branschvinnare_svensk_2024.png" alt="Branschvinnare" width="650" height="148" class="h-12 w-full object-contain brightness-0 invert opacity-40" />
					</div>
				</div>
			</div>
			<div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
				<div class="md:grid md:grid-cols-2 md:gap-8">
					<div>
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white/90">Tjänster</h3>
						<ul role="list" class="mt-5 list-none space-y-4 p-0">
							{footerNavigation.services.map((item) => (
								<li><a href={item.href} class="micro-link text-sm leading-6 text-white/44 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
					<div class="mt-10 md:mt-0">
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white/90">Byrå</h3>
						<ul role="list" class="mt-5 list-none space-y-4 p-0">
							{footerNavigation.agency.map((item) => (
								<li><a href={item.href} class="micro-link text-sm leading-6 text-white/44 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
				</div>
				<div class="md:grid md:grid-cols-2 md:gap-8">
					<div>
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white/90">Konsult</h3>
						<ul role="list" class="mt-5 list-none space-y-4 p-0">
							{footerNavigation.consultant.map((item) => (
								<li><a href={item.href} class="micro-link text-sm leading-6 text-white/44 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
					<div class="mt-10 md:mt-0">
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white/90">Företaget</h3>
						<ul role="list" class="mt-5 list-none space-y-4 p-0">
							{footerNavigation.company.map((item) => (
								<li><a href={item.href} class="micro-link text-sm leading-6 text-white/44 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</div>

		<div class="mt-10 border-t border-white/8 pt-10 md:flex md:items-center md:justify-between">
			<div class="flex space-x-6 md:order-2">
				{footerNavigation.social.map((item) => (
					<a href={item.href} class="micro-link text-white/32 hover:text-white" target="_blank" rel="noreferrer">
						<span class="sr-only">{item.name}</span>
						<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
						</svg>
					</a>
				))}
			</div>
			<div class="md:order-1">
				<p class="mt-8 text-xs leading-5 text-white/32 md:mt-0">&copy; 2026 New Customers Sweden AB. All rights reserved.</p>
			</div>
		</div>
	</div>
</footer>
