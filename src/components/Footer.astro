---
import { footerNavigation } from '../data/navigation';
---

<footer class="bg-gray" aria-labelledby="footer-heading">
	<h2 id="footer-heading" class="sr-only">Footer</h2>
	<div class="site-container py-16">
		<div class="xl:grid xl:grid-cols-3 xl:gap-8">
			<div class="flex flex-col items-center space-y-6 lg:items-start">
				<a href="/">
					<img src="/newcustomers.svg" alt="Logo" width="240" height="36" class="h-20" />
				</a>
				<img src="/ntc.png" alt="NTC" width="650" height="148" class="w-auto h-20 -mr-20" />
				<img src="/SIGILL_SKOLD_VANSTER_STOR_VIT_TEXT.png" alt="Sigill" width="650" height="148" class="w-auto h-20 -mr-20" />
				<img src="/branschvinnare_svensk_2024.png" alt="Branschvinnare" width="650" height="148" class="w-auto h-20" />
			</div>
			<div class="grid grid-cols-2 gap-8 mt-16 xl:col-span-2 xl:mt-0">
				<div class="md:grid md:grid-cols-2 md:gap-8">
					<div>
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white">Tjänster</h3>
						<ul role="list" class="p-0 mt-5 space-y-4 list-none">
							{footerNavigation.services.map((item) => (
								<li><a href={item.href} class="text-sm leading-6 text-gray-300 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
					<div class="mt-10 md:mt-0">
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white">Byrå</h3>
						<ul role="list" class="p-0 mt-5 space-y-4 list-none">
							{footerNavigation.agency.map((item) => (
								<li><a href={item.href} class="text-sm leading-6 text-gray-300 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
				</div>
				<div class="md:grid md:grid-cols-2 md:gap-8">
					<div>
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white">Konsult</h3>
						<ul role="list" class="p-0 mt-5 space-y-4 list-none">
							{footerNavigation.consultant.map((item) => (
								<li><a href={item.href} class="text-sm leading-6 text-gray-300 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
					<div class="mt-10 md:mt-0">
						<h3 class="mt-0 text-sm font-semibold leading-6 text-white">Företaget</h3>
						<ul role="list" class="p-0 mt-5 space-y-4 list-none">
							{footerNavigation.company.map((item) => (
								<li><a href={item.href} class="text-sm leading-6 text-gray-300 hover:text-white">{item.name}</a></li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</div>

		<div class="pt-10 mt-10 border-t border-white/10 md:flex md:items-center md:justify-between">
			<div class="flex space-x-6 md:order-2">
				{footerNavigation.social.map((item) => (
					<a href={item.href} class="text-gray-500 hover:text-gray-400" target="_blank" rel="noreferrer">
						<span class="sr-only">{item.name}</span>
						<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-6 h-6 text-white" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
						</svg>
					</a>
				))}
			</div>
			<p class="mt-10 text-xs leading-5 text-gray-400 md:order-1 md:mt-0">© 2024 New Customers Sweden AB All rights reserved.</p>
		</div>
	</div>
</footer>
