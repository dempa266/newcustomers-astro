---
import { Button, Checkbox, Input } from '@heroui/react';
---

<section class="pt-8" data-contact-form-small>
	<div class="w-full">
		<p class="text-primary font-bold text-center my-auto hidden" data-success></p>
		<form action="#" method="POST" class="lg:flex-auto" data-form>
			<div class="max-w-5xl mx-auto sm:flex space-y-6 sm:space-y-0 sm:space-x-2">
				<Input type="text" name="name" placeholder="Namn" autoComplete="name" aria-label="Namn" className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6" />
				<Input type="text" name="phone" autoComplete="phone" placeholder="Telefon" aria-label="Telefon" className="block w-full rounded-md border-0 px-3.5 py-2 text-gray shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6" />
				<Button type="submit" className="block w-56 rounded-md bg-primary px-3.5 py-2.5 text-center text-sm text-black shadow-sm hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
					Skicka
				</Button>
			</div>
			<div class="mt-5 space-x-2">
				<Checkbox id="gdpr-small" name="gdpr" className="text-sm leading-6 text-white">
					Genom att skicka detta meddelande godkänner du att vi lagrar och hanterar dina personuppgifter i enlighet med vår
					<a href="/integritetspolicy/" class="text-primary">integritetspolicy</a>.
				</Checkbox>
			</div>
			<p class="text-red-500 hidden" data-error></p>
		</form>
	</div>
</section>

<script is:inline>
	document.querySelectorAll('[data-contact-form-small]').forEach((root) => {
		if (root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const form = root.querySelector('[data-form]');
		const success = root.querySelector('[data-success]');
		const error = root.querySelector('[data-error]');

		if (!form || !success || !error) return;

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			error.textContent = '';
			error.classList.add('hidden');

			const gdpr = form.querySelector('[name="gdpr"]');
			if (!(gdpr instanceof HTMLInputElement) || !gdpr.checked) {
				error.textContent = 'Du behöver godkänna vår integritetspolicy innan du kan skicka meddelandet.';
				error.classList.remove('hidden');
				return;
			}

			const target = event.currentTarget;
			const formData = new FormData();
			formData.append('cc_name', target.elements.name?.value || '');
			formData.append('cc_phone', target.elements.phone?.value || '');
			formData.append('apiKey', '6321a3ced5af44fcd7338ac0');

			document.cookie.split('; ').forEach((cookie) => {
				const [key, value] = cookie.split('=');
				if (key === '_cc' && value) formData.append('cookie', value);
			});

			try {
				await fetch('https://api.customerconnect.se/submissions', {
					method: 'POST',
					body: formData,
				});
				success.textContent = 'Tack för ditt meddelande!';
				success.classList.remove('hidden');
				form.classList.add('hidden');
				target.reset();
			} catch {
				error.textContent = 'Något gick fel. Försök igen.';
				error.classList.remove('hidden');
			}
		});
	});
</script>
