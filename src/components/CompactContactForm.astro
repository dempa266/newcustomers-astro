---
import { Checkbox, Input } from '@heroui/react';

const fieldClassName =
	'field block w-full border border-border bg-white px-3.5 py-2.5 text-base leading-6 text-gray shadow-none placeholder:text-muted focus:border-primary focus:ring-2 focus:ring-primary/30';
const submitClassName =
	'button button--primary inline-flex h-11 w-full sm:w-56 items-center justify-center rounded-[var(--radius-button)] border border-primary bg-primary px-6 text-base font-semibold text-dark shadow-sm transition duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 hover:border-primary-dark hover:bg-primary-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-background';
---

<section class="pt-8" data-contact-form-small>
	<div class="w-full">
		<p class="text-primary font-bold text-center my-auto hidden" data-success></p>
		<form action="#" method="POST" class="lg:flex-auto" data-form>
			<div class="max-w-5xl mx-auto sm:flex space-y-4 sm:space-y-0 sm:space-x-3">
				<Input type="text" name="name" placeholder="Namn" autoComplete="name" aria-label="Namn" className={fieldClassName} />
				<Input type="text" name="phone" autoComplete="phone" placeholder="Telefon" aria-label="Telefon" className={fieldClassName} />
				<button type="submit" class={submitClassName}>
					Skicka
				</button>
			</div>
			<div class="mt-5">
				<Checkbox id="gdpr-small" name="gdpr" className="text-sm leading-6 text-white/75">
					Genom att skicka detta meddelande godkänner du att vi lagrar och hanterar dina personuppgifter i enlighet med vår
					<a href="/integritetspolicy/" class="text-primary">integritetspolicy</a>.
				</Checkbox>
			</div>
			<p class="text-red-500 hidden" data-error></p>
		</form>
	</div>
</section>

<script is:inline>
	document.querySelectorAll('[data-contact-form-small]').forEach((root) => {
		if (root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const form = root.querySelector('[data-form]');
		const success = root.querySelector('[data-success]');
		const error = root.querySelector('[data-error]');

		if (!form || !success || !error) return;

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			error.textContent = '';
			error.classList.add('hidden');

			const gdpr = form.querySelector('[name="gdpr"]');
			if (!(gdpr instanceof HTMLInputElement) || !gdpr.checked) {
				error.textContent = 'Du behöver godkänna vår integritetspolicy innan du kan skicka meddelandet.';
				error.classList.remove('hidden');
				return;
			}

			const target = event.currentTarget;
			const formData = new FormData();
			formData.append('cc_name', target.elements.name?.value || '');
			formData.append('cc_phone', target.elements.phone?.value || '');
			formData.append('apiKey', '6321a3ced5af44fcd7338ac0');

			document.cookie.split('; ').forEach((cookie) => {
				const [key, value] = cookie.split('=');
				if (key === '_cc' && value) formData.append('cookie', value);
			});

			try {
				await fetch('https://api.customerconnect.se/submissions', {
					method: 'POST',
					body: formData,
				});
				success.textContent = 'Tack för ditt meddelande!';
				success.classList.remove('hidden');
				form.classList.add('hidden');
				target.reset();
			} catch {
				error.textContent = 'Något gick fel. Försök igen.';
				error.classList.remove('hidden');
			}
		});
	});
</script>
