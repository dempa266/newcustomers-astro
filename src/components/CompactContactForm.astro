---
const fieldClassName =
	'field h-11 w-full rounded-xl border border-black/12 bg-white px-3.5 text-sm text-foreground placeholder:text-foreground/44 outline-none transition focus:border-primary/50 focus:ring-2 focus:ring-primary/25';
const submitClassName =
	'button button--primary inline-flex h-11 w-full items-center justify-center rounded-[var(--radius-button)] border border-transparent bg-primary px-6 text-sm font-semibold tracking-[0.08em] text-dark uppercase shadow-[0_10px_24px_-18px_rgba(213,164,56,0.9)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/65 focus-visible:ring-offset-2 focus-visible:ring-offset-background sm:w-auto';
---

<section class="pt-2" aria-label="Snabbkontakt" data-contact-form-small>
	<div class="w-full">
		<p class="mb-4 hidden rounded-lg border border-emerald-300/60 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700" data-success></p>

		<form action="#" method="POST" class="space-y-4" data-form>
			<div class="grid gap-3 sm:grid-cols-[1fr_1fr_auto] sm:items-center">
				<input type="text" name="name" placeholder="Namn" autoComplete="name" aria-label="Namn" class={fieldClassName} required />
				<input type="tel" name="phone" autoComplete="tel" placeholder="Telefon" aria-label="Telefon" class={fieldClassName} required />
				<button type="submit" class={submitClassName}>Skicka</button>
			</div>

			<label for="gdpr-small" class="flex items-start gap-3 rounded-xl border border-black/10 bg-white/80 px-3 py-3 text-sm leading-relaxed text-foreground/64">
				<input id="gdpr-small" name="gdpr" type="checkbox" class="mt-1 h-4 w-4 rounded border-black/30 accent-primary" />
				<span>
					Genom att skicka detta meddelande godkänner du att vi lagrar och hanterar dina personuppgifter i enlighet med vår
					<a href="/integritetspolicy/" class="font-semibold text-foreground underline decoration-primary/35 decoration-2 underline-offset-3 hover:decoration-primary">integritetspolicy</a>.
				</span>
			</label>

			<p class="hidden rounded-lg border border-red-300/65 bg-red-50 px-4 py-3 text-sm font-medium text-red-700" data-error></p>
		</form>
	</div>
</section>

<script is:inline>
	document.querySelectorAll('[data-contact-form-small]').forEach((root) => {
		if (root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const form = root.querySelector('[data-form]');
		const success = root.querySelector('[data-success]');
		const error = root.querySelector('[data-error]');

		if (!form || !success || !error) return;

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			error.textContent = '';
			error.classList.add('hidden');

			const gdpr = form.querySelector('[name="gdpr"]');
			if (!(gdpr instanceof HTMLInputElement) || !gdpr.checked) {
				error.textContent = 'Du behöver godkänna vår integritetspolicy innan du kan skicka meddelandet.';
				error.classList.remove('hidden');
				return;
			}

			const target = event.currentTarget;
			const formData = new FormData();
			formData.append('cc_name', target.elements.name?.value || '');
			formData.append('cc_phone', target.elements.phone?.value || '');
			formData.append('apiKey', '6321a3ced5af44fcd7338ac0');

			document.cookie.split('; ').forEach((cookie) => {
				const [key, value] = cookie.split('=');
				if (key === '_cc' && value) formData.append('cookie', value);
			});

			try {
				await fetch('https://api.customerconnect.se/submissions', {
					method: 'POST',
					body: formData,
				});
				success.textContent = 'Tack för ditt meddelande!';
				success.classList.remove('hidden');
				form.classList.add('hidden');
				target.reset();
			} catch {
				error.textContent = 'Något gick fel. Försök igen.';
				error.classList.remove('hidden');
			}
		});
	});
</script>
