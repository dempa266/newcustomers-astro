---
import type { NavArticleLink, NavColumn } from '../../data/navigation';

interface Props {
	title: string;
	path: string;
	columns?: NavColumn[];
	latestArticles?: NavArticleLink[];
	onLight?: boolean;
}

const { title, path, columns = [], latestArticles = [], onLight = false } = Astro.props as Props;
const hasArticles = latestArticles.length > 0;
---

<li class="relative mb-0 list-none">
	<details class="group/nav" data-nav-dropdown>
		<summary
			class:list={[
				'micro-link inline-flex list-none cursor-pointer items-center gap-x-2 rounded-full border px-4 py-2 text-base font-medium leading-tight transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70',
				onLight
					? 'border-transparent text-foreground/80 hover:bg-black/5 hover:text-foreground'
					: 'border-transparent text-white/84 hover:border-white/18 hover:bg-white/12 hover:text-white',
			]}
		>
			<span>{title}</span>
			<svg
				class="h-3 w-3 transition-transform duration-200 group-open/nav:rotate-180"
				viewBox="0 0 12 12"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
				aria-hidden="true"
			>
				<path d="M2.25 4.5 6 8.25 9.75 4.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</summary>
		<div class="pointer-events-none absolute left-1/2 z-30 mt-4 w-screen max-w-6xl -translate-x-1/2 px-4 opacity-0 translate-y-2 scale-[0.98] transition-all duration-250 ease-out group-open/nav:pointer-events-auto group-open/nav:opacity-100 group-open/nav:translate-y-0 group-open/nav:scale-100">
			<div class:list={[
				'w-full rounded-[1.9rem] border p-6 leading-6 shadow-2xl backdrop-blur-xl',
				onLight
					? 'border-border/70 bg-white/95 text-foreground shadow-black/10'
					: 'border-white/14 bg-[#0d0d1a]/94 text-white shadow-black/45',
			]}>
				<div class:list={['grid gap-8', hasArticles ? 'lg:grid-cols-[2fr_1fr]' : '']}>
					<div class="grid gap-5 md:grid-cols-3">
						{columns.map((column) => (
							<div class:list={['rounded-2xl p-4', onLight ? 'bg-surface-secondary/70' : 'border border-white/10 bg-white/5']}>
								<h3 class:list={['text-xs font-semibold uppercase tracking-[0.08em]', onLight ? 'text-muted' : 'text-white/50']}>{column.title}</h3>
								<div class="mt-3 space-y-0.5">
									{column.links.map((item) => (
										<a
											href={item.path}
											class:list={[
												'micro-link block rounded-xl px-3 py-2 text-[0.9375rem] font-medium no-underline transition',
												onLight
													? 'text-foreground hover:bg-white hover:text-primary hover:no-underline'
													: 'text-white/80 hover:bg-white/10 hover:text-white hover:no-underline',
											]}
										>
											{item.label}
										</a>
									))}
								</div>
							</div>
						))}
					</div>

					{hasArticles && (
						<div class:list={['rounded-2xl p-4', onLight ? 'bg-surface-secondary/70' : 'border border-white/10 bg-white/5']}>
							<h3 class:list={['text-xs font-semibold uppercase tracking-[0.08em]', onLight ? 'text-muted' : 'text-white/50']}>Populärt</h3>
							<div class="mt-3 space-y-1">
								{latestArticles.map((article) => (
									<a
										href={article.path}
										class:list={[
											'block rounded-xl px-3 py-2.5 no-underline transition',
											onLight
												? 'hover:bg-white hover:no-underline'
												: 'hover:bg-white/10 hover:no-underline',
										]}
									>
										<span class:list={[
											'block text-[0.9375rem] font-medium',
											onLight ? 'text-foreground' : 'text-white/80',
										]}>{article.label}</span>
										{article.description && (
											<span class:list={[
												'block mt-0.5 text-sm',
												onLight ? 'text-foreground/60' : 'text-white/44',
											]}>{article.description}</span>
										)}
									</a>
								))}
							</div>
						</div>
					)}
				</div>
			</div>
		</div>
	</details>
</li>

<script is:inline>
	document.querySelectorAll('[data-nav-dropdown]').forEach((root) => {
		if (root.dataset.bound === 'true') return;
		root.dataset.bound = 'true';

		const summary = root.querySelector('summary');
		summary?.addEventListener('click', () => {
			requestAnimationFrame(() => {
				if (!root.hasAttribute('open')) return;
				document.querySelectorAll('[data-nav-dropdown][open]').forEach((other) => {
					if (other !== root) other.removeAttribute('open');
				});
			});
		});

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Node) || root.contains(target)) return;
			root.removeAttribute('open');
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') root.removeAttribute('open');
		});
	});
</script>
