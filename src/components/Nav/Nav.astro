---
import Dropdown from './Dropdown.astro';
import type { NavGroup, NavLink } from '../../data/navigation';

interface Props {
	groups?: NavGroup[];
	links?: NavLink[];
	onLight?: boolean;
}

const { groups = [], links = [], onLight = false } = Astro.props as Props;
---

<nav class="flex items-center h-full">
	<ul class="flex items-center list-none gap-1 m-0 p-0">
		{groups.map((group) => (
			<Dropdown title={group.title} path={group.path} columns={group.columns} latestArticles={group.latestArticles} onLight={onLight} />
		))}
		{links.map((link) => (
			<li class="mb-0 list-none">
				<a
					class:list={[
						'micro-link inline-flex items-center rounded-full border px-4 py-2 text-base font-medium leading-tight no-underline transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/70',
						onLight
							? 'border-transparent text-foreground/80 hover:bg-black/5 hover:text-foreground hover:no-underline'
							: 'border-transparent text-white/84 hover:border-white/18 hover:bg-white/12 hover:text-white hover:no-underline',
					]}
					href={link.path}
				>
					{link.label}
				</a>
			</li>
		))}
	</ul>
</nav>
