---
type ButtonVariant =
  | "primary"
  | "secondary"
  | "transparent"
  | "tertiary"
  | "default";
type ButtonSize = "sm" | "md" | "lg";

interface Props {
  type?: ButtonVariant;
  size?: ButtonSize;
  text: string;
  href?: string;
  target?: string;
  rel?: string;
  class?: string;
}

const {
  type = "default",
  size = "md",
  text,
  href = "#",
  target,
  rel,
  class: className = "",
} = Astro.props as Props;

const baseClasses =
  "button inline-flex items-center justify-center border font-semibold tracking-wide leading-none no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2 focus-visible:ring-offset-background active:scale-95 cursor-pointer";

const classesBySize: Record<ButtonSize, string> = {
  sm: "h-10 px-5 text-sm",
  md: "h-12 px-7 text-base",
  lg: "h-14 px-9 text-lg",
};

const classesByType: Record<ButtonVariant, string> = {
  primary:
    "button--primary border-transparent bg-primary text-primary-foreground",
  secondary:
    "border-border/60 bg-surface text-foreground shadow-sm",
  transparent:
    "border-white/22 bg-white/6 text-white backdrop-blur-sm",
  tertiary:
    "border-transparent bg-transparent text-foreground",
  default:
    "button--primary border-transparent bg-primary text-primary-foreground",
};

const layerClassesByType: Record<ButtonVariant, string> = {
  primary: "button__layer bg-[linear-gradient(120deg,var(--primary),var(--primary-dark))]",
  secondary: "button__layer bg-[linear-gradient(120deg,var(--surface-secondary),var(--surface-tertiary))]",
  transparent:
    "button__layer bg-[linear-gradient(120deg,rgba(255,255,255,0.26),rgba(255,255,255,0.1))]",
  tertiary: "button__layer bg-[linear-gradient(120deg,var(--surface-secondary),var(--surface-tertiary))]",
  default: "button__layer bg-[linear-gradient(120deg,var(--primary),var(--primary-dark))]",
};

const classes =
  `${baseClasses} ${classesBySize[size]} ${classesByType[type]} ${className}`.trim();
const computedRel =
  rel ?? (target === "_blank" ? "noreferrer noopener" : undefined);
---

<a href={href} class={classes} target={target} rel={computedRel}>
  <span class={layerClassesByType[type]} aria-hidden="true"></span>
  <span class="button__label">{text}</span>
</a>
