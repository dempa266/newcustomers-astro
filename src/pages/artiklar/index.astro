---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SubHero from '../../sections/SubHero.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';

const categoryLabels: Record<string, string> = {
	seo: 'SEO',
	sem: 'SEM',
	'google-ads': 'Google Ads',
	cro: 'CRO',
	'digital-marknadsforing': 'Digital Marknadsföring',
};

const articles = (await getCollection('artiklar')).sort(
	(a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime(),
);

const categories = [...new Set(articles.map((a) => a.data.category))];
---

<Layout title="Artiklar om digital marknadsföring | new customers" description="Expertkunskap och praktiska guider om SEO, SEM, CRO och digital marknadsföring från teamet på new customers.">
	<SubHero
		data={{
			title: 'Artiklar och guider',
			description: 'Expertkunskap om digital marknadsföring, SEO, Google Ads och konverteringsoptimering. Praktiska guider som hjälper dig att fatta bättre beslut.',
			noBackgroundImage: true,
			primaryCta: { text: 'Kontakta oss', href: '/kontakt/' },
			secondaryCta: { text: 'Om oss', href: '/om-oss/' },
		}}
	/>

	{categories.map((category) => {
		const categoryArticles = articles.filter((a) => a.data.category === category);
		const label = categoryLabels[category] ?? category.charAt(0).toUpperCase() + category.slice(1);
		return (
			<section class="section-spacing" aria-label={`${label}-artiklar`}>
				<div class="site-container">
					<div class="mx-auto max-w-4xl">
						<div class="section-intro section-intro--spaced" data-reveal>
							<SectionEyebrow text={label} />
							<h2>Artiklar om {label}</h2>
						</div>
						<div class="section-after-intro border-t border-black/6" data-reveal-children>
							{categoryArticles.map((article) => {
								const slugParts = article.id.split('/');
								const slug = slugParts[slugParts.length - 1];
								const href = `/artiklar/${article.data.category}/${slug}/`;
								const date = new Date(article.data.publishedDate).toLocaleDateString('sv-SE', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								});
								return (
									<a href={href} class="group flex gap-6 border-b border-black/6 py-8 transition hover:bg-black/[0.015]">
										{article.data.image && (
											<div class="hidden sm:block shrink-0 w-48 h-32 overflow-hidden rounded-xl border border-black/6">
												<img
													src={article.data.image}
													alt={article.data.imageAlt ?? article.data.title}
													width="192"
													height="128"
													class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
													loading="lazy"
												/>
											</div>
										)}
										<div class="flex flex-col justify-center">
											<p class="type-micro-label text-primary">{label}</p>
											<h2 class="mt-1 text-lg font-medium leading-snug text-foreground group-hover:text-primary transition-colors">{article.data.title}</h2>
											<p class="mt-2 text-sm text-foreground/60 line-clamp-2">{article.data.description}</p>
											<div class="mt-3 flex items-center gap-3 text-sm text-foreground/40">
												<span>{article.data.author.name}</span>
												<span aria-hidden="true" class="text-foreground/20">·</span>
												<time datetime={article.data.publishedDate}>{date}</time>
											</div>
										</div>
									</a>
								);
							})}
						</div>
						<div class="mt-6" data-reveal>
							<a href={`/artiklar/${category}/`} class="type-micro-label text-primary hover:text-primary/80 transition">
								Alla {label}-artiklar →
							</a>
						</div>
					</div>
				</div>
			</section>
		);
	})}
</Layout>
